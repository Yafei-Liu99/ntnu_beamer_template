\mode<presentation>

\newif\ifbeamer@secheader
\beamer@secheaderfalse

\ProcessOptionsBeamer

\RequirePackage{refcount}

% ============================================================
% NTNU Colors (official brand) — must be defined before use
% ============================================================
\definecolor{ntnublue}{RGB}{0,80,158}
\xdefinecolor{ntnusky}{RGB}{221,231,238}

% ============================================================
% Suppress default navigation symbols
% ============================================================
\setbeamertemplate{navigation symbols}{}

\makeatletter
\newcommand{\frameofframes}{/}
\newcommand{\setframeofframes}[1]{\renewcommand{\frameofframes}{#1}}

% ============================================================
% Autoframe system: track subsections and frames for navigation
% ============================================================
\newcounter{yf@gframe}

\AtBeginSubsection{%
  \global\expandafter\xdef
    \csname yf@subname@\the\c@section @\the\c@subsection\endcsname
    {\insertsubsectionhead}%
  \@ifundefined{yf@nsub@\the\c@section}{\global\@namedef{yf@nsub@\the\c@section}{0}}{}%
  \ifnum\@nameuse{yf@nsub@\the\c@section}<\c@subsection\relax
    \global\@namedef{yf@nsub@\the\c@section}{\the\c@subsection}%
  \fi
  \global\@namedef{yf@frames@\the\c@section @\the\c@subsection}{}%
}

\newcommand{\yf@register}{%
  \stepcounter{yf@gframe}%
  \edef\yf@curlist{\@nameuse{yf@frames@\the\c@section @\the\c@subsection}}%
  \ifx\yf@curlist\@empty
    \global\expandafter\xdef
      \csname yf@frames@\the\c@section @\the\c@subsection\endcsname{\theyf@gframe}%
  \else
    \global\expandafter\xdef
      \csname yf@frames@\the\c@section @\the\c@subsection\endcsname
      {\yf@curlist,\theyf@gframe}%
  \fi
}

\newenvironment{autoframe}[1]{%
  \yf@register
  \begin{frame}[environment=autoframe,label=yf@auto@\arabic{yf@gframe}]{#1}%
}{%
  \end{frame}%
}

% ============================================================
% Auto section intro page
% ============================================================
\AtBeginSection[]{%
  \begin{frame}[label=yf@sec@\the\value{section}]
    \centering\vspace*{\fill}
    {\Huge\bfseries\color{ntnublue}\insertsectionhead}\par\vspace{1em}
    {\large\color{gray}Introduction}
    \vspace*{\fill}
  \end{frame}%
}

\AtBeginSubsection[]{}

% ============================================================
% Headline: section name + subsection names with progress dots
% ============================================================
\setbeamercolor{section in head/foot}{bg=ntnublue!15,fg=black}

\newcommand{\yf@dot}[1]{%
  \ifnum\insertframenumber=\getpagerefnumber{yf@auto@#1}\relax
    \hyperlink{yf@auto@#1}{\textcolor{ntnublue}{$\bullet$}}%
  \else
    \hyperlink{yf@auto@#1}{\textcolor{ntnublue!35}{$\circ$}}%
  \fi\hspace{2pt}%
}

\def\yf@firstof#1,#2\@nil{\def\yf@firstitem{#1}}

\newcommand{\yf@rsub}[2]{%
  \edef\yf@list{\@nameuse{yf@frames@#1@#2}}%
  \ifx\yf@list\@empty\else
    \expandafter\yf@firstof\yf@list,\@nil
    \hyperlink{yf@auto@\yf@firstitem}{\@nameuse{yf@subname@#1@#2}}~%
    \@for\yf@e:=\yf@list\do{\yf@dot{\yf@e}}%
  \fi
}

\setbeamertemplate{headline}{%
  \leavevmode
  \begin{beamercolorbox}[wd=\paperwidth,ht=3.25ex,dp=1.5ex,leftskip=1em,rightskip=1em]{section in head/foot}%
    \usebeamerfont{section in head/foot}%
    \ifnum\insertsectionnumber>0
      \@ifundefined{yf@nsub@\the\value{section}}{}{%
        \hyperlink{yf@sec@\the\value{section}}{\textbf{\insertsectionhead:}}\hfill
        \@tempcnta=1\relax
        \edef\yf@N{\@nameuse{yf@nsub@\insertsectionnumber}}%
        \@whilenum\@tempcnta<\yf@N\do{%
          \yf@rsub{\insertsectionnumber}{\the\@tempcnta}\hfill
          \advance\@tempcnta by 1\relax
        }%
        \yf@rsub{\insertsectionnumber}{\the\@tempcnta}%
      }%
    \fi
  \end{beamercolorbox}%
}

% ============================================================
% Frame title
% ============================================================
\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,leftskip=.3cm,%
    rightskip=.3cm plus1fil,vmode]{frametitle}%
    \vskip.35ex%
    \usebeamerfont*{frametitle}\strut\insertframetitle%
    \ifx\insertframesubtitle\@empty%
      \strut\par%
    \else%
      \par{\usebeamerfont*{framesubtitle}%
        {\usebeamercolor[fg]{framesubtitle}\strut\insertframesubtitle}\strut\par}%
    \fi%
    \vskip.35ex%
  \end{beamercolorbox}%
}

% ============================================================
% Title page
% ============================================================
\setbeamertemplate{title page}
{
  \vbox{
    \vskip1.2em%
    \begin{beamercolorbox}[sep=8pt,center,rounded=true,shadow=true]{title}
      \usebeamerfont{title}\inserttitle\par%
      \ifx\insertsubtitle\@empty%
      \else%
        \vskip0.5em%
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
      \fi%
    \end{beamercolorbox}%
    \vskip0.5em%
    \begin{beamercolorbox}[sep=8pt,center]{author}
      \usebeamerfont{author}\insertauthor
    \end{beamercolorbox}
    \vskip0.2em%
    \begin{beamercolorbox}[sep=8pt,center]{institute}
      \usebeamerfont{institute}\insertinstitute
      \vskip0.5em%
      \begin{beamercolorbox}[sep=8pt,center]{date}
        \usebeamerfont{date}\insertdate
      \end{beamercolorbox}
    \end{beamercolorbox}
  }
}

% ============================================================
% Footline: author/institute (top), title/page (bottom)
% ============================================================
\setbeamertemplate{footline}
{%
  \begin{beamercolorbox}[colsep=1.5pt]{upper separation line foot}
  \end{beamercolorbox}
  \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
    leftskip=.3cm,rightskip=.3cm plus1fil]{author in head/foot}%
    \leavevmode{\usebeamerfont{author in head/foot}\insertshortauthor}%
    \hfill%
    {\usebeamerfont{institute in head/foot}%
     \usebeamercolor[fg]{institute in head/foot}\insertshortinstitute}%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
    leftskip=.3cm,rightskip=.3cm plus1fil]{title in head/foot}%
    {\usebeamerfont{title in head/foot}\insertshorttitle}%
    \hfill%
    {\usebeamerfont{frame number}\usebeamercolor[fg]{frame number}%
     \insertframenumber~\frameofframes~\inserttotalframenumber}
  \end{beamercolorbox}%
  \begin{beamercolorbox}[colsep=1.5pt]{lower separation line foot}
  \end{beamercolorbox}
}
\makeatother

% ============================================================
% Inner theme & blocks
% ============================================================
\useinnertheme{circles}

\setbeamertemplate{theorems}[numbered]
\setbeamertemplate{blocks}[rounded][shadow=true]

% ============================================================
% Color assignments
% ============================================================
\setbeamercolor{footline}{bg=ntnublue}
\setbeamercolor{frametitle}{bg=ntnublue,fg=white}
\setbeamercolor{title}{bg=ntnublue}
\setbeamerfont{frametitle}{size=\large}
\setbeamertemplate{bibliography item}[text]
\setbeamertemplate{caption}[numbered]

\setbeamercolor{uppercol}{bg=white}
\setbeamercolor{lowercol}{bg=white}

\setbeamercolor{palette primary}{use=structure,fg=white,bg=structure.fg}
\setbeamercolor{palette secondary}{use=structure,fg=white,bg=structure.fg!75!black}
\setbeamercolor{palette tertiary}{use=structure,fg=white,bg=structure.fg!50!black}
\setbeamercolor{palette quaternary}{fg=white,bg=structure.fg!50!black}
\setbeamercolor{titlelike}{parent=palette primary}

\setbeamercolor{block title}{bg=ntnublue,fg=white}
\setbeamercolor{block body}{bg=ntnusky}
\setbeamercolor*{block title example}{use={normal text,example text},bg=white,fg=ntnublue}
\setbeamercolor{fine separation line}{}
\setbeamercolor{item projected}{fg=white}
\setbeamercolor{palette sidebar primary}{use=normal text,fg=normal text.fg}
\setbeamercolor{palette sidebar quaternary}{use=structure,fg=structure.fg}
\setbeamercolor{palette sidebar secondary}{use=structure,fg=structure.fg}
\setbeamercolor{palette sidebar tertiary}{use=normal text,fg=normal text.fg}
\setbeamercolor{section in sidebar}{fg=brown}
\setbeamercolor{section in sidebar shaded}{fg=grey}
\setbeamercolor{separation line}{}
\setbeamercolor{sidebar}{bg=ntnublue}
\setbeamercolor{sidebar}{parent=palette primary}
\setbeamercolor{structure}{fg=ntnublue}
\setbeamercolor{subsection in sidebar}{fg=brown}
\setbeamercolor{subsection in sidebar shaded}{fg=grey}

\mode
<all>
