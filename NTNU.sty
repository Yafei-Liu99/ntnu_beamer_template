\mode<presentation>

\newif\ifbeamer@secheader
\beamer@secheaderfalse

\ProcessOptionsBeamer

\RequirePackage{refcount}
\RequirePackage{tikz}

% ============================================================
% NTNU Color Palette
%
% Gradient logic (top → bottom of each slide):
%   ntnusky    — lightest: headline navigation bar
%   ntnublue   — medium:   frametitle, block titles
%   ntnudark   — darkest:  footline anchor
%
% Block hierarchy (light → dark = illustrative → critical):
%   example    — ntnublue!50   (softest, illustrative)
%   standard   — ntnublue!85   (default emphasis)
%   alert      — ntnudark      (strongest, attention)
% ============================================================
\definecolor{ntnublue}{RGB}{0,80,158}
\definecolor{ntnudark}{RGB}{0,56,112}
\xdefinecolor{ntnusky}{RGB}{221,231,238}

% ============================================================
% Suppress default navigation symbols
% ============================================================
\setbeamertemplate{navigation symbols}{}

\makeatletter
\newcommand{\frameofframes}{/}
\newcommand{\setframeofframes}[1]{\renewcommand{\frameofframes}{#1}}

% ============================================================
% Autoframe system: track subsections and frames for navigation
% ============================================================
\newcounter{yf@gframe}

\AtBeginSubsection{%
  \global\expandafter\xdef
    \csname yf@subname@\the\c@section @\the\c@subsection\endcsname
    {\insertsubsectionhead}%
  \@ifundefined{yf@nsub@\the\c@section}{\global\@namedef{yf@nsub@\the\c@section}{0}}{}%
  \ifnum\@nameuse{yf@nsub@\the\c@section}<\c@subsection\relax
    \global\@namedef{yf@nsub@\the\c@section}{\the\c@subsection}%
  \fi
  \global\@namedef{yf@frames@\the\c@section @\the\c@subsection}{}%
}

\newcommand{\yf@register}{%
  \stepcounter{yf@gframe}%
  \edef\yf@curlist{\@nameuse{yf@frames@\the\c@section @\the\c@subsection}}%
  \ifx\yf@curlist\@empty
    \global\expandafter\xdef
      \csname yf@frames@\the\c@section @\the\c@subsection\endcsname{\theyf@gframe}%
  \else
    \global\expandafter\xdef
      \csname yf@frames@\the\c@section @\the\c@subsection\endcsname
      {\yf@curlist,\theyf@gframe}%
  \fi
}

\newenvironment{autoframe}[1]{%
  \yf@register
  \begin{frame}[environment=autoframe,label=yf@auto@\arabic{yf@gframe}]{#1}%
}{%
  \end{frame}%
}

% ============================================================
% Auto section intro page
% ============================================================
\AtBeginSection[]{%
  \begin{frame}[label=yf@sec@\the\value{section}]
    \centering\vspace*{\fill}
    {\fontsize{28}{34}\bfseries\color{ntnublue}\insertsectionhead}\par
    \vspace{0.6em}
    {\color{ntnublue!30}\rule{0.25\paperwidth}{0.8pt}}\par
    \vspace{0.6em}
    {\normalsize\color{ntnublue!45}Section~\insertsectionnumber}
    \vspace*{\fill}
  \end{frame}%
}

% ============================================================
% Headline: navigation bar — lightest tier
% ============================================================
\setbeamercolor{section in head/foot}{bg=ntnusky,fg=ntnublue!80!black}
\setbeamerfont{section in head/foot}{size=\scriptsize}

\newcommand{\yf@dot}[1]{%
  \ifnum\insertframenumber=\getpagerefnumber{yf@auto@#1}\relax
    \hyperlink{yf@auto@#1}{\textcolor{ntnublue}{$\bullet$}}%
  \else
    \hyperlink{yf@auto@#1}{\textcolor{ntnublue!30}{$\circ$}}%
  \fi\hspace{2pt}%
}

\def\yf@firstof#1,#2\@nil{\def\yf@firstitem{#1}}

\newcommand{\yf@rsub}[2]{%
  \edef\yf@list{\@nameuse{yf@frames@#1@#2}}%
  \ifx\yf@list\@empty\else
    \expandafter\yf@firstof\yf@list,\@nil
    \hyperlink{yf@auto@\yf@firstitem}{\@nameuse{yf@subname@#1@#2}}~%
    \@for\yf@e:=\yf@list\do{\yf@dot{\yf@e}}%
  \fi
}

\setbeamertemplate{headline}{%
  \leavevmode
  \begin{beamercolorbox}[wd=\paperwidth,ht=3.25ex,dp=1.5ex,leftskip=1em,rightskip=1em]{section in head/foot}%
    \usebeamerfont{section in head/foot}%
    \ifnum\insertsectionnumber>0
      \@ifundefined{yf@nsub@\the\value{section}}{}{%
        \hyperlink{yf@sec@\the\value{section}}{\textbf{\insertsectionhead:}}\hfill
        \@tempcnta=1\relax
        \edef\yf@N{\@nameuse{yf@nsub@\insertsectionnumber}}%
        \@whilenum\@tempcnta<\yf@N\do{%
          \yf@rsub{\insertsectionnumber}{\the\@tempcnta}\hfill
          \advance\@tempcnta by 1\relax
        }%
        \yf@rsub{\insertsectionnumber}{\the\@tempcnta}%
      }%
    \fi
  \end{beamercolorbox}%
}

% ============================================================
% Frame title — medium tier
% ============================================================
\setbeamertemplate{frametitle}{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,leftskip=.3cm,%
    rightskip=.3cm plus1fil,vmode]{frametitle}%
    \vskip.35ex%
    \usebeamerfont*{frametitle}\strut\insertframetitle%
    \ifx\insertframesubtitle\@empty%
      \strut\par%
    \else%
      \par{\usebeamerfont*{framesubtitle}%
        {\usebeamercolor[fg]{framesubtitle}\strut\insertframesubtitle}\strut\par}%
    \fi%
    \vskip.35ex%
  \end{beamercolorbox}%
}

% ============================================================
% Title page
% ============================================================
\setbeamertemplate{title page}
{
  \vbox{
    \vskip1.2em%
    \begin{beamercolorbox}[sep=8pt,center,rounded=true,shadow=true]{title}
      \usebeamerfont{title}\inserttitle\par%
      \ifx\insertsubtitle\@empty%
      \else%
        \vskip0.5em%
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
      \fi%
    \end{beamercolorbox}%
    \vskip0.5em%
    \begin{beamercolorbox}[sep=8pt,center]{author}
      \usebeamerfont{author}\insertauthor
    \end{beamercolorbox}
    \vskip0.2em%
    \begin{beamercolorbox}[sep=8pt,center]{institute}
      \usebeamerfont{institute}\insertinstitute
      \vskip0.5em%
      \begin{beamercolorbox}[sep=8pt,center]{date}
        \usebeamerfont{date}\insertdate
      \end{beamercolorbox}
    \end{beamercolorbox}
  }
}

% ============================================================
% Footline — darkest tier (two-level gradient)
% ============================================================
\setbeamertemplate{footline}
{%
  \begin{beamercolorbox}[colsep=1.5pt]{upper separation line foot}
  \end{beamercolorbox}
  \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
    leftskip=.3cm,rightskip=.3cm plus1fil]{author in head/foot}%
    \leavevmode{\usebeamerfont{author in head/foot}\insertshortauthor}%
    \hfill%
    {\usebeamerfont{institute in head/foot}%
     \usebeamercolor[fg]{institute in head/foot}\insertshortinstitute}%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
    leftskip=.3cm,rightskip=.3cm plus1fil]{title in head/foot}%
    {\usebeamerfont{title in head/foot}\insertshorttitle}%
    \hfill%
    {\usebeamerfont{frame number}\usebeamercolor[fg]{frame number}%
     \insertframenumber~\frameofframes~\inserttotalframenumber}
  \end{beamercolorbox}%
  \begin{beamercolorbox}[colsep=1.5pt]{lower separation line foot}
  \end{beamercolorbox}
}
\makeatother

% ============================================================
% Inner theme & blocks
% ============================================================
\useinnertheme{circles}

\setbeamertemplate{theorems}[numbered]
\setbeamertemplate{blocks}[rounded][shadow=true]

% ============================================================
% Structural color assignments
% ============================================================

% Frame chrome: light top → dark bottom
\setbeamercolor{frametitle}{bg=ntnublue,fg=white}
\setbeamerfont{frametitle}{size=\large}
\setbeamercolor{author in head/foot}{bg=ntnublue,fg=white!85}
\setbeamercolor{title in head/foot}{bg=ntnudark,fg=white!85}
\setbeamercolor{institute in head/foot}{fg=white!70}
\setbeamercolor{frame number}{fg=white!70}
\setbeamercolor{footline}{bg=ntnudark}
\setbeamercolor{upper separation line foot}{bg=ntnublue!50}

% Title page
\setbeamercolor{title}{bg=ntnublue,fg=white}
\setbeamercolor{subtitle}{fg=white!85}
\setbeamercolor{author}{fg=ntnublue!80!black}
\setbeamercolor{institute}{fg=ntnublue!60!black}
\setbeamercolor{date}{fg=ntnublue!50!black}

% Blocks: gradient encodes importance
\setbeamercolor{block title}{bg=ntnublue!85,fg=white}
\setbeamercolor{block body}{bg=ntnusky}
\setbeamercolor{block title alerted}{bg=ntnudark,fg=white}
\setbeamercolor{block body alerted}{bg=ntnublue!8}
\setbeamercolor{block title example}{bg=ntnublue!45,fg=white}
\setbeamercolor{block body example}{bg=ntnusky!60!white}

% Structure & items
\setbeamercolor{structure}{fg=ntnublue}
\setbeamercolor{item projected}{fg=white,bg=ntnublue!75}
\setbeamercolor{itemize item}{fg=ntnublue!80}
\setbeamercolor{itemize subitem}{fg=ntnublue!55}
\setbeamercolor{enumerate item}{fg=ntnublue}
\setbeamercolor{enumerate subitem}{fg=ntnublue!65}

% TOC: sections prominent, subsections softer
\setbeamercolor{section in toc}{fg=ntnublue}
\setbeamercolor{subsection in toc}{fg=ntnublue!60!black}
\setbeamercolor{section number projected}{bg=ntnublue,fg=white}

% Palettes
\setbeamercolor{palette primary}{fg=white,bg=ntnublue}
\setbeamercolor{palette secondary}{fg=white,bg=ntnublue!75!black}
\setbeamercolor{palette tertiary}{fg=white,bg=ntnublue!50!black}
\setbeamercolor{palette quaternary}{fg=white,bg=ntnudark}
\setbeamercolor{titlelike}{parent=palette primary}

% Misc
\setbeamertemplate{bibliography item}[text]
\setbeamertemplate{caption}[numbered]
\setbeamercolor{caption name}{fg=ntnublue!80}
\setbeamercolor{fine separation line}{}
\setbeamercolor{separation line}{}

% ============================================================
% Thank-you page — NTNU branded closing slide
% ============================================================
\newcommand{\makethankyou}[1][]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture,overlay]
      \fill[ntnusky] (current page.north west)
        rectangle ([yshift=-0.8cm]current page.north east);
      \fill[ntnublue] ([yshift=1.2cm]current page.south west)
        rectangle ([yshift=0.6cm]current page.south east);
      \fill[ntnudark] (current page.south west)
        rectangle ([yshift=0.6cm]current page.south east);
    \end{tikzpicture}
    \vspace*{\fill}
    \begin{center}
      {\fontsize{32}{38}\selectfont\bfseries\color{ntnublue}Thank You!}\par
      \vspace{0.6em}
      {\color{ntnublue!30}\rule{0.25\paperwidth}{0.8pt}}\par
      \vspace{0.8em}
      {\normalsize\color{ntnublue!80!black}\insertauthor}\par
      \vspace{0.3em}
      \def\yf@tkemail{#1}%
      \ifx\yf@tkemail\@empty\else
        {\small\texttt{\color{ntnublue!60!black}#1}}\par
        \vspace{0.3em}
      \fi
      {\small\color{ntnublue!60!black}\insertinstitute}\par
      \vspace{1.2em}
      \includegraphics[width=0.18\linewidth]{pic/ntnu-logo.pdf}
    \end{center}
    \vspace*{\fill}
  \end{frame}%
}

\mode
<all>
